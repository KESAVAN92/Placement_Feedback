PORT=5000
# Replace <username>, <password>, and <clusterName> with your Atlas credentials.
# Example: mongodb+srv://user:pass@cluster0.abcde.mongodb.net/placement-feedback-system?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<clusterName>.mongodb.net/placement-feedback-system
JWT_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@placement.com
ADMIN_PASSWORD=admin123
CLIENT_URLS=http://localhost:3000,http://localhost:3001
